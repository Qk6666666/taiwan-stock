function switchITab(t){
  const tabs=['kline','chips','news','related','nextday'];
  document.querySelectorAll('.itab').forEach((b,i)=>b.classList.toggle('active',tabs[i]===t));
  document.querySelectorAll('.ipanel').forEach(p=>p.classList.remove('active'));
  document.getElementById('ipanel-'+t).classList.add('active');
  if(t==='chips'&&CUR&&QUOTE_DATA)renderChips(CUR,QUOTE_DATA,CANDLES);
  if(t==='nextday'&&CUR&&QUOTE_DATA)runNextDayPrediction(CUR,QUOTE_DATA,CANDLES,NEWS_DATA);
}

function f2(n){return n!=null?(+n).toFixed(2):'—';}
function fv(n){return n!=null?(+n).toLocaleString():'—';}
function fmc(n){if(!n)return'—';if(n>=1e12)return(n/1e12).toFixed(2)+'兆';if(n>=1e8)return(n/1e8).toFixed(0)+'億';return n.toLocaleString();}
function fmn(n){if(n==null||isNaN(+n))return'—';const v=+n;if(Math.abs(v)>=1000)return(v/1000).toFixed(0)+'K';return v.toLocaleString();}

function renderQuote(id,name,q){
  const up=q.regularMarketChange>=0,cc=up?'up-c':'dn-c',tc=up?'up-tag':'dn-tag',sign=up?'+':'';
  let rng='';
  if(q.fiftyTwoWeekHigh&&q.fiftyTwoWeekLow){const pct=Math.min(100,Math.max(0,((q.regularMarketPrice-q.fiftyTwoWeekLow)/(q.fiftyTwoWeekHigh-q.fiftyTwoWeekLow))*100));rng=`<div class="range-wrap"><div class="range-top"><span>52W低 ${f2(q.fiftyTwoWeekLow)}</span><span>目前位置 ${pct.toFixed(0)}%</span><span>52W高 ${f2(q.fiftyTwoWeekHigh)}</span></div><div class="range-track"><div class="range-grad" style="width:100%"></div><div class="range-dot" style="left:calc(${pct}% - 6px)"></div></div></div>`;}
  document.getElementById('quoteSection').innerHTML=`
  <div class="stock-hero">
    <div><div style="font-size:24px;font-weight:700;margin-bottom:4px;">${name}</div><div style="font-size:12px;color:var(--text3);font-family:'JetBrains Mono',monospace;">${id}.TW　·　台灣證券交易所</div><div style="margin-top:6px;display:flex;flex-wrap:wrap;gap:4px;">${getSectorTag(id)}</div></div>
    <div><div class="hero-price ${cc}">${f2(q.regularMarketPrice)}</div><div style="text-align:right;"><span class="hero-change ${tc}">${sign}${f2(q.regularMarketChange)}　${sign}${(+q.regularMarketChangePercent).toFixed(2)}%</span></div></div>
  </div>
  <div class="metrics-grid">
    <div class="metric-card"><div class="mc-label">開盤</div><div class="mc-value">${q.regularMarketOpen?f2(q.regularMarketOpen):`<span style="color:var(--text3);font-size:13px;">盤後</span>`}</div></div>
    <div class="metric-card"><div class="mc-label">昨收</div><div class="mc-value">${f2(q.regularMarketPreviousClose)}</div></div>
    <div class="metric-card"><div class="mc-label">今日最高</div><div class="mc-value ${q.regularMarketDayHigh?'up-c':''}">${q.regularMarketDayHigh?f2(q.regularMarketDayHigh):`<span style="color:var(--text3);font-size:13px;">盤後</span>`}</div></div>
    <div class="metric-card"><div class="mc-label">今日最低</div><div class="mc-value ${q.regularMarketDayLow?'dn-c':''}">${q.regularMarketDayLow?f2(q.regularMarketDayLow):`<span style="color:var(--text3);font-size:13px;">盤後</span>`}</div></div>
    <div class="metric-card"><div class="mc-label">成交量</div><div class="mc-value" style="font-size:15px;">${fv(q.regularMarketVolume)}</div></div>
    <div class="metric-card"><div class="mc-label">市值</div><div class="mc-value" style="font-size:15px;">${fmc(q.marketCap)}</div></div>
    <div class="metric-card"><div class="mc-label">本益比 PE</div><div class="mc-value">${q.trailingPE?((+q.trailingPE).toFixed(1)):'—'}</div></div>
    <div class="metric-card"><div class="mc-label">52W 高 / 低</div><div class="mc-value" style="font-size:13px;"><span class="up-c">${f2(q.fiftyTwoWeekHigh)}</span> / <span class="dn-c">${f2(q.fiftyTwoWeekLow)}</span></div></div>
  </div>${rng}
  <div style="font-size:11px;color:var(--text3);text-align:right;margin-top:9px;">查詢時間：${new Date().toLocaleString('zh-TW',{hour12:false})}　·　延遲約 15 分鐘</div>`;
}

// ─── 籌碼分析 ───
async function renderChips(id,q,candles){
  const el=document.getElementById('chipsArea');if(!el)return;
  if(CHIPS_DATA!==null){renderChipsUI(id,q,candles,CHIPS_DATA);return;}
  el.innerHTML='<div class="loading-box"><div class="spinner"></div>載入三大法人、融資融券…</div>';
  const[inst,margin]=await Promise.all([fetchInstitutional(id).catch(()=>null),fetchMargin(id).catch(()=>null)]);
  CHIPS_DATA={inst,margin};renderChipsUI(id,q,candles,CHIPS_DATA);
}

function renderChipsUI(id,q,candles,data){
  const el=document.getElementById('chipsArea');if(!el)return;
  const inst=data.inst,margin=data.margin;
  const ok=inst||margin;
  let instHtml='';
  if(inst){
    const total=inst.total;const tc=total>0?'var(--up)':'var(--down)';const maxAbs=Math.max(Math.abs(inst.foreign.net),Math.abs(inst.trust.net),Math.abs(inst.dealer.net),1);
    instHtml=`<div style="background:var(--bg3);border:1px solid var(--border);border-radius:13px;padding:15px;margin-bottom:12px;"><div style="display:flex;justify-content:space-between;margin-bottom:12px;"><span style="font-size:12px;font-weight:500;color:var(--text2);text-transform:uppercase;">三大法人買賣超</span><span style="font-size:11px;color:var(--text3);">${inst.date}</span></div><div style="font-size:22px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${tc};margin-bottom:12px;">${total>0?'+':''}${fmn(total)} 張　${total>0?'↑ 淨買超':'↓ 淨賣超'}</div>${[{label:'外資及陸資',data:inst.foreign,color:'#7c7ff7'},{label:'投信',data:inst.trust,color:'#4ade80'},{label:'自營商',data:inst.dealer,color:'#fbbf24'}].map(({label,data,color})=>{const net=data.net;const up=net>0;const w=Math.min(100,Math.abs(net)/maxAbs*100);return`<div style="margin-bottom:10px;"><div style="display:flex;justify-content:space-between;margin-bottom:4px;"><span style="font-size:11px;color:var(--text3);">${label}</span><span style="font-size:12px;font-weight:600;font-family:'JetBrains Mono',monospace;color:${up?'var(--up)':'var(--down)'};">${net>0?'+':''}${fmn(net)}</span></div><div style="height:4px;background:var(--border2);border-radius:3px;overflow:hidden;"><div style="width:${w}%;height:100%;background:${up?color:'#ef4444'};border-radius:3px;"></div></div></div>`;}).join('')}</div>`;
  }else{instHtml=`<div style="background:var(--bg3);border:1px dashed var(--border2);border-radius:13px;padding:14px;margin-bottom:12px;font-size:12px;color:var(--text3);">⚠️ 三大法人資料今日暫無（非交易時間或資料尚未更新）</div>`;}
  let marginHtml='';
  if(margin){
    const mr=margin.marginBalance>0?(margin.shortBalance/margin.marginBalance*100):0;
    marginHtml=`<div style="background:var(--bg3);border:1px solid var(--border);border-radius:13px;padding:15px;margin-bottom:12px;"><div style="font-size:12px;font-weight:500;color:var(--text2);text-transform:uppercase;margin-bottom:12px;">融資 / 融券　<span style="font-size:10px;color:var(--text3);">${margin.date}</span></div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:11px;"><div style="background:var(--bg4);border:1px solid var(--border);border-radius:10px;padding:12px;"><div style="font-size:11px;color:var(--text3);margin-bottom:4px;">融資餘額</div><div style="font-size:17px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--up);">${fmn(margin.marginBalance)}</div><div style="font-size:10px;color:${margin.marginChange>0?'var(--up)':margin.marginChange<0?'var(--down)':'var(--text3)'};margin-top:3px;">${margin.marginChange>=0?'↑+':'↓'}${fmn(margin.marginChange)} 張</div></div><div style="background:var(--bg4);border:1px solid var(--border);border-radius:10px;padding:12px;"><div style="font-size:11px;color:var(--text3);margin-bottom:4px;">融券餘額</div><div style="font-size:17px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--down);">${fmn(margin.shortBalance)}</div><div style="font-size:10px;color:${margin.shortChange>0?'var(--up)':margin.shortChange<0?'var(--down)':'var(--text3)'};margin-top:3px;">${margin.shortChange>=0?'↑+':'↓'}${fmn(margin.shortChange)} 張</div></div><div style="background:var(--bg4);border:1px solid var(--border);border-radius:10px;padding:12px;"><div style="font-size:11px;color:var(--text3);margin-bottom:4px;">券資比</div><div style="font-size:17px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${mr>20?'var(--up)':'var(--text)'};">${mr.toFixed(1)}%</div><div style="font-size:10px;color:var(--text3);margin-top:3px;">${mr>30?'🔺偏高':mr>15?'🟡中等':'🟢偏低'}</div></div></div><div style="font-size:10px;color:var(--text3);">融資買進 ${fmn(margin.marginBuy)} / 賣出 ${fmn(margin.marginSell)}　·　融券賣出 ${fmn(margin.shortSell)} / 買進 ${fmn(margin.shortBuy)}</div></div>`;
  }else{marginHtml=`<div style="background:var(--bg3);border:1px dashed var(--border2);border-radius:13px;padding:14px;margin-bottom:12px;font-size:12px;color:var(--text3);">⚠️ 融資融券資料暫時無法取得</div>`;}
  let volHtml='';
  if(candles.length>=5){const rc=candles.slice(-10);const maxV=Math.max(...rc.map(x=>x.v||0))||1;const rows=rc.map((c,i)=>{const up=c.c>=c.o;const date=`${c.t.getMonth()+1}/${c.t.getDate()}`;const chg=rc[i-1]?((c.c-rc[i-1].c)/rc[i-1].c*100):0;const vp=((c.v||0)/maxV*100).toFixed(0);return`<tr><td style="font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text3);padding:4px 6px;">${date}</td><td style="font-size:11px;color:${up?'var(--up)':'var(--down)'};padding:4px 6px;">${up?'▲':'▼'}${Math.abs(chg).toFixed(2)}%</td><td style="font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text2);padding:4px 6px;">${fmn(c.v||0)}</td><td style="padding:4px 6px;min-width:70px;"><div style="height:6px;width:${vp}%;background:${up?'rgba(240,74,88,.5)':'rgba(29,184,112,.5)'};border-radius:3px;min-width:2px;"></div></td></tr>`;}).join('');volHtml=`<div><div style="font-size:12px;color:var(--text2);font-weight:500;margin-bottom:9px;text-transform:uppercase;">近10日量價</div><table style="width:100%;border-collapse:collapse;"><thead><tr style="border-bottom:1px solid var(--border);"><th style="font-size:10px;color:var(--text3);text-align:left;padding:4px 6px;">日期</th><th style="font-size:10px;color:var(--text3);text-align:left;padding:4px 6px;">漲跌</th><th style="font-size:10px;color:var(--text3);text-align:left;padding:4px 6px;">成交量</th><th style="font-size:10px;color:var(--text3);text-align:left;padding:4px 6px;min-width:70px;">量能圖</th></tr></thead><tbody>${rows}</tbody></table></div>`;}
  el.innerHTML=`<div style="display:inline-flex;align-items:center;font-size:10px;padding:3px 9px;border-radius:4px;margin-bottom:10px;${ok?'background:rgba(29,184,112,.1);color:#4ade80;border:1px solid rgba(29,184,112,.25);':'background:rgba(240,160,48,.1);color:var(--gold);border:1px solid rgba(240,160,48,.25);'}">${ok?'✅ 資料已載入（台灣證交所）':'⚠️ 資料暫時無法取得'}</div>${instHtml}${marginHtml}${volHtml}<div style="font-size:10px;color:var(--text3);margin-top:8px;">⚠️ 僅供參考，不構成投資建議。<span style="cursor:pointer;color:var(--accent2);margin-left:10px;" onclick="CHIPS_DATA=null;renderChips('${id}',QUOTE_DATA,CANDLES)">↺ 重新載入</span></div>`;
}

// ─── K-Line ───
function loadKline(range,interval){if(!CUR)return;document.querySelectorAll('.pbtn').forEach(b=>b.classList.toggle('active',(b.textContent==='日K'&&interval==='1d'&&range==='1mo')||(b.textContent==='3月'&&interval==='1d'&&range==='3mo')||(b.textContent==='週K'&&interval==='1wk')||(b.textContent==='月K'&&interval==='1mo')));const ld=document.getElementById('klineLoading');ld.style.display='flex';ld.textContent='載入 K 線…';document.getElementById('klineVerdict').innerHTML='<span class="badge b-load">AI 分析中…</span>';fetchKline(CUR,range,interval).then(cs=>{CANDLES=cs;ld.style.display='none';if(!cs.length){ld.textContent='K線載入失敗';ld.style.display='flex';return;}analyzeKline(cs,interval);});}
function renderKlineFromData(candles,interval){const ld=document.getElementById('klineLoading');if(!ld)return;if(!candles||!candles.length){ld.textContent='K線載入失敗';ld.style.display='flex';return;}ld.style.display='none';analyzeKline(candles,interval);}
let _klineBg=0,_klinePAD={},_klineInterval='1d',_tooltipMoveHandler=null,_tooltipLeaveHandler=null;
function drawKline(candles,interval,annotations){
  const canvas=document.getElementById('klineCanvas');if(!canvas)return;_klineInterval=interval;
  const wrap=canvas.parentElement;const dpr=window.devicePixelRatio||1;const W=wrap.clientWidth;const KLINE_H=260;
  canvas.style.height=KLINE_H+'px';canvas.width=W*dpr;canvas.height=KLINE_H*dpr;canvas.style.width=W+'px';
  const ctx=canvas.getContext('2d');ctx.scale(dpr,dpr);
  const PAD={top:18,right:14,bottom:8,left:56};_klinePAD=PAD;
  const cW=W-PAD.left-PAD.right,cH=KLINE_H-PAD.top-PAD.bottom;
  ctx.fillStyle='#111318';ctx.fillRect(0,0,W,KLINE_H);
  const n=candles.length;if(!n)return;
  const prices=candles.flatMap(c=>[c.h,c.l]);const mn=Math.min(...prices),mx=Math.max(...prices);const pd=(mx-mn)*0.07;const lo=mn-pd,hi=mx+pd;
  const toY=p=>PAD.top+cH-((p-lo)/(hi-lo))*cH;const bg=cW/n;_klineBg=bg;const bw=Math.max(1.5,bg-1.5);
  for(let i=0;i<=5;i++){const p=lo+(hi-lo)*(i/5),y=toY(p);ctx.strokeStyle='#1e2235';ctx.lineWidth=.5;ctx.beginPath();ctx.moveTo(PAD.left,y);ctx.lineTo(W-PAD.right,y);ctx.stroke();ctx.fillStyle='#454d68';ctx.font=`10px 'JetBrains Mono',monospace`;ctx.textAlign='right';ctx.fillText(p.toFixed(1),PAD.left-3,y+4);}
  function cma(arr,p){return arr.map((_,i)=>{if(i<p-1)return null;return arr.slice(i-p+1,i+1).reduce((a,c)=>a+c.c,0)/p;});}
  function dma(mas,col){ctx.beginPath();ctx.strokeStyle=col;ctx.lineWidth=1;let s=false;mas.forEach((v,i)=>{if(v==null)return;const x=PAD.left+i*bg+bg/2,y=toY(v);if(!s){ctx.moveTo(x,y);s=true;}else ctx.lineTo(x,y);});ctx.stroke();}
  dma(cma(candles,5),'rgba(250,200,70,.85)');dma(cma(candles,20),'rgba(120,140,255,.85)');dma(cma(candles,60),'rgba(250,100,100,.6)');
  candles.forEach((c,i)=>{const x=PAD.left+i*bg+bg/2,up=c.c>=c.o,col=up?'#f04a58':'#1db870';ctx.strokeStyle=col;ctx.fillStyle=col;ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(x,toY(c.h));ctx.lineTo(x,toY(c.l));ctx.stroke();const bt=toY(Math.max(c.o,c.c)),bb=toY(Math.min(c.o,c.c));ctx.fillRect(x-bw/2,bt,bw,Math.max(1.5,bb-bt));});
  ctx.font=`10px 'JetBrains Mono',monospace`;ctx.textAlign='left';ctx.fillStyle='rgba(250,200,70,.9)';ctx.fillText('MA5',PAD.left+4,PAD.top+13);ctx.fillStyle='rgba(120,140,255,.9)';ctx.fillText('MA20',PAD.left+34,PAD.top+13);ctx.fillStyle='rgba(250,100,100,.7)';ctx.fillText('MA60',PAD.left+68,PAD.top+13);
  (annotations||[]).forEach(ann=>{const idx=Math.round(ann.index);if(idx<0||idx>=n)return;const c=candles[idx];if(!c)return;const x=PAD.left+idx*bg+bg/2;const bull=ann.type==='bull';const col=bull?'#f04a58':'#1db870';const lbl=ann.label||(bull?'看多':'看空');ctx.save();ctx.setLineDash([3,4]);ctx.strokeStyle=col;ctx.globalAlpha=.28;ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(x,PAD.top);ctx.lineTo(x,PAD.top+cH);ctx.stroke();ctx.restore();ctx.save();ctx.font='bold 12px sans-serif';ctx.fillStyle=col;ctx.textAlign='center';ctx.fillText(bull?'▲':'▼',x,bull?toY(c.l)+17:toY(c.h)-17);ctx.font=`bold 10px 'Noto Sans TC',sans-serif`;const tw=Math.max(ctx.measureText(lbl).width+14,36),ph=17,pr=4;const pillY=bull?toY(c.l)+23:toY(c.h)-27;const pillX=Math.min(Math.max(x-tw/2,PAD.left+1),W-PAD.right-tw-1);const bgc=bull?'rgba(240,74,88,.18)':'rgba(29,184,112,.18)';const brc=bull?'rgba(240,74,88,.55)':'rgba(29,184,112,.55)';ctx.fillStyle=bgc;ctx.strokeStyle=brc;ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(pillX+pr,pillY);ctx.lineTo(pillX+tw-pr,pillY);ctx.arc(pillX+tw-pr,pillY+pr,pr,-Math.PI/2,0);ctx.lineTo(pillX+tw,pillY+ph-pr);ctx.arc(pillX+tw-pr,pillY+ph-pr,pr,0,Math.PI/2);ctx.lineTo(pillX+pr,pillY+ph);ctx.arc(pillX+pr,pillY+ph-pr,pr,Math.PI/2,Math.PI);ctx.lineTo(pillX,pillY+pr);ctx.arc(pillX+pr,pillY+pr,pr,Math.PI,-Math.PI/2);ctx.closePath();ctx.fill();ctx.stroke();ctx.fillStyle=col;ctx.textAlign='left';ctx.fillText(lbl,pillX+7,pillY+12);ctx.restore();});
  setupTooltip(canvas,candles,PAD,bg,toY,W);drawVolume(candles,PAD,bg);
}
function setupTooltip(canvas,candles,PAD,bg,toY,W){
  if(_tooltipMoveHandler)canvas.removeEventListener('mousemove',_tooltipMoveHandler);
  if(_tooltipLeaveHandler)canvas.removeEventListener('mouseleave',_tooltipLeaveHandler);
  let tip=document.getElementById('klineTooltip');if(!tip){tip=document.createElement('div');tip.id='klineTooltip';canvas.parentElement.style.position='relative';canvas.parentElement.appendChild(tip);}
  _tooltipMoveHandler=e=>{const rect=canvas.getBoundingClientRect();const mx=e.clientX-rect.left;const idx=Math.floor((mx-PAD.left)/bg);if(idx<0||idx>=candles.length){tip.style.display='none';return;}const c=candles[idx];if(!c)return;const up=c.c>=c.o;const chg=c.o>0?((c.c-c.o)/c.o*100):0;tip.innerHTML=`<div style="color:#6b7494;font-size:11px;margin-bottom:6px;">${c.t.getFullYear()}/${String(c.t.getMonth()+1).padStart(2,'0')}/${String(c.t.getDate()).padStart(2,'0')}</div><div style="color:${up?'#f04a58':'#1db870'};font-weight:700;font-size:14px;margin-bottom:5px;">${up?'▲':'▼'} ${chg>=0?'+':''}${chg.toFixed(2)}%</div><div style="display:flex;justify-content:space-between;gap:16px;"><span style="color:#555e78;">開</span><span>${c.o.toFixed(2)}</span></div><div style="display:flex;justify-content:space-between;gap:16px;"><span style="color:#555e78;">收</span><strong style="color:${up?'#f04a58':'#1db870'}">${c.c.toFixed(2)}</strong></div><div style="display:flex;justify-content:space-between;gap:16px;"><span style="color:#555e78;">高</span><span style="color:#f04a58">${c.h.toFixed(2)}</span></div><div style="display:flex;justify-content:space-between;gap:16px;"><span style="color:#555e78;">低</span><span style="color:#1db870">${c.l.toFixed(2)}</span></div>${c.v?`<div style="display:flex;justify-content:space-between;gap:16px;margin-top:3px;border-top:1px solid #1e2235;padding-top:4px;"><span style="color:#555e78;">量</span><span>${c.v>=1000?(c.v/1000).toFixed(0)+'K':c.v}</span></div>`:''}`;const tipW=160,tipH=tip.offsetHeight||145;let tx=mx+16,ty=e.clientY-rect.top-tipH/2;if(tx+tipW>W-PAD.right-5)tx=mx-tipW-12;if(tx<0)tx=4;if(ty<4)ty=4;if(ty+tipH>260-4)ty=260-tipH-4;tip.style.left=tx+'px';tip.style.top=ty+'px';tip.style.display='block';};
  _tooltipLeaveHandler=()=>{tip.style.display='none';};
  canvas.addEventListener('mousemove',_tooltipMoveHandler);canvas.addEventListener('mouseleave',_tooltipLeaveHandler);
}
function drawVolume(candles,kPAD,bg){
  const vc=document.getElementById('volCanvas');if(!vc)return;const wrap=vc.parentElement;const dpr=window.devicePixelRatio||1;const W=wrap.clientWidth;const VOL_H=70;vc.style.height=VOL_H+'px';vc.width=W*dpr;vc.height=VOL_H*dpr;vc.style.width=W+'px';const ctx=vc.getContext('2d');ctx.scale(dpr,dpr);ctx.fillStyle='#111318';ctx.fillRect(0,0,W,VOL_H);const PAD={top:6,right:kPAD.right,bottom:18,left:kPAD.left};const cH=VOL_H-PAD.top-PAD.bottom;const n=candles.length;if(!n)return;const vols=candles.map(c=>c.v||0);const maxV=Math.max(...vols)||1;const barW=Math.max(1.5,bg-1.5);const vma5=vols.map((_,i)=>{if(i<4)return null;return vols.slice(i-4,i+1).reduce((a,b)=>a+b,0)/5;});candles.forEach((c,i)=>{const v=c.v||0;const x=PAD.left+i*bg+bg/2;const barH=Math.max(1,(v/maxV)*cH);const y=PAD.top+cH-barH;ctx.fillStyle=c.c>=c.o?'rgba(240,74,88,.55)':'rgba(29,184,112,.55)';ctx.fillRect(x-barW/2,y,barW,barH);});ctx.beginPath();ctx.strokeStyle='rgba(250,200,70,.7)';ctx.lineWidth=1;let started=false;vma5.forEach((v,i)=>{if(v==null)return;const x=PAD.left+i*bg+bg/2;const y=PAD.top+cH-(v/maxV)*cH;if(!started){ctx.moveTo(x,y);started=true;}else ctx.lineTo(x,y);});ctx.stroke();const fmtVol=v=>v>=1e8?`${(v/1e8).toFixed(1)}億`:v>=1e4?`${(v/1000).toFixed(0)}K`:String(v);ctx.fillStyle='#454d68';ctx.font=`9px 'JetBrains Mono',monospace`;ctx.textAlign='right';ctx.fillText(fmtVol(maxV),PAD.left-3,PAD.top+10);const minSp=_klineInterval==='1mo'?50:34;let lastX=-999;candles.forEach((c,i)=>{const x=PAD.left+i*bg+bg/2;if(x-lastX<minSp)return;const lbl=_klineInterval==='1mo'?`${c.t.getFullYear()}/${c.t.getMonth()+1}`:`${c.t.getMonth()+1}/${c.t.getDate()}`;ctx.fillStyle='#454d68';ctx.textAlign='center';ctx.font=`9px 'JetBrains Mono',monospace`;ctx.fillText(lbl,x,VOL_H-3);lastX=x;});
}
function ruleBasedKlineAnnotations(candles){const ann=[],n=candles.length;if(n<5)return[];for(let i=6;i<n;i++){if(i<21)continue;const ma5a=candles.slice(i-5,i).reduce((a,c)=>a+c.c,0)/5;const ma5b=candles.slice(i-6,i-1).reduce((a,c)=>a+c.c,0)/5;const ma20a=candles.slice(i-20,i).reduce((a,c)=>a+c.c,0)/20;const ma20b=candles.slice(i-21,i-1).reduce((a,c)=>a+c.c,0)/20;if(ma5b<ma20b&&ma5a>=ma20a&&!ann.find(a=>a.label==='黃金交叉'))ann.push({index:i,type:'bull',label:'黃金交叉',reason:'MA5上穿MA20'});if(ma5b>ma20b&&ma5a<=ma20a&&!ann.find(a=>a.label==='死亡交叉'))ann.push({index:i,type:'bear',label:'死亡交叉',reason:'MA5下穿MA20'});}if(n>=15){const prior=candles.slice(-15,-5);const pH=Math.max(...prior.map(c=>c.h)),pL=Math.min(...prior.map(c=>c.l));const last=candles[n-1];if(last.c>pH)ann.push({index:n-1,type:'bull',label:'突破壓力',reason:`突破${pH.toFixed(2)}`});else if(last.c<pL)ann.push({index:n-1,type:'bear',label:'跌破支撐',reason:`跌破${pL.toFixed(2)}`});}candles.slice(-5).forEach((c,i)=>{const body=Math.abs(c.c-c.o),range=c.h-c.l;if(range>0&&body/range>0.7&&ann.length<4){if(c.c>c.o&&(c.c-c.o)/c.o>0.025)ann.push({index:n-5+i,type:'bull',label:'長紅K',reason:`大陽線`});else if(c.c<c.o&&(c.o-c.c)/c.o>0.025)ann.push({index:n-5+i,type:'bear',label:'長黑K',reason:`大陰線`});}});return ann.slice(0,4);}
async function analyzeKline(candles,interval){const ruleAnn=ruleBasedKlineAnnotations(candles);drawKline(candles,interval,ruleAnn);renderKlineVerdict(ruleAnn);const recent=candles.slice(-20).map((c,i,arr)=>({i:candles.length-20+i,date:`${c.t.getMonth()+1}/${c.t.getDate()}`,o:+c.o.toFixed(2),h:+c.h.toFixed(2),l:+c.l.toFixed(2),c:+c.c.toFixed(2),chg:arr[i-1]?+(((c.c-arr[i-1].c)/arr[i-1].c)*100).toFixed(2):0}));const totalLen=candles.length;const prompt=`以下是最近${recent.length}根K線（${interval==='1d'?'日K':interval==='1wk'?'週K':'月K'}），格式[index,日期,開,高,低,收,漲跌%]：\n${recent.map(c=>`[${c.i},${c.date},${c.o},${c.h},${c.l},${c.c},${c.chg}%]`).join('\n')}\n\n請識別2~4個最重要技術形態訊號，標示index（必須在${totalLen-recent.length}到${totalLen-1}之間），type為bull或bear，標籤4字以內。只回覆JSON陣列：[{"index":數字,"type":"bull"或"bear","label":"標籤","reason":"說明"}]`;try{const txt=await callClaude('你是台股技術分析師，只回覆JSON陣列格式，不加說明或markdown。',prompt);const parsed=JSON.parse(txt);if(!Array.isArray(parsed)||!parsed.length)return;const clamped=parsed.slice(0,5).map(a=>({...a,index:Math.min(Math.max(Math.round(+a.index),0),candles.length-1)}));drawKline(candles,interval,clamped);renderKlineVerdict(clamped);}catch(e){}}
function renderKlineVerdict(annotations){const el=document.getElementById('klineVerdict');if(!el)return;if(!annotations.length){el.innerHTML='<span class="badge b-neu">無明確訊號</span>';return;}const bull=annotations.filter(a=>a.type==='bull').length,bear=annotations.filter(a=>a.type==='bear').length;const ov=bull>bear?{cls:'b-bull',icon:'📈',txt:'整體偏多'}:bear>bull?{cls:'b-bear',icon:'📉',txt:'整體偏空'}:{cls:'b-amber',icon:'➡️',txt:'多空均衡'};el.innerHTML=`<span class="badge ${ov.cls}">${ov.icon} ${ov.txt}</span>`+annotations.map(a=>`<span class="badge ${a.type==='bull'?'b-bull':'b-bear'}" title="${a.reason||''}">${a.type==='bull'?'▲':'▼'} ${a.label}</span>`).join('');}

