async function loadLowBase(){if(lowBaseLoaded)return;const el=document.getElementById('lowBaseList');if(!el)return;el.innerHTML='<div style="text-align:center;padding:14px 0;"><div class="spinner" style="width:18px;height:18px;margin:0 auto 7px;"></div><div style="font-size:11px;color:var(--text3);">分析低基期個股…</div></div>';const results=await Promise.allSettled(LOW_BASE.map(async c=>{const q=await fetchQuote(c.id).catch(()=>null);return{...c,q};}));const valid=results.filter(r=>r.status==='fulfilled'&&r.value.q?.regularMarketPrice).map(r=>r.value).map(item=>{const q=item.q;const price=q.regularMarketPrice;const wkH=q.fiftyTwoWeekHigh,wkL=q.fiftyTwoWeekLow;const pct52=wkH&&wkL?((price-wkL)/(wkH-wkL)*100):null;const pe=q.trailingPE?+q.trailingPE:null;return{...item,price,pct52,pe,score:(pct52!=null?100-pct52:50)+(pe&&pe<15?20:pe&&pe<25?10:0),chgPct:q.regularMarketChangePercent||0};}).sort((a,b)=>b.score-a.score);if(!valid.length){el.innerHTML='<div style="font-size:11px;color:var(--text3);text-align:center;padding:14px;">載入失敗</div>';return;}lowBaseLoaded=true;const now=new Date().toLocaleString('zh-TW',{hour12:false,hour:'2-digit',minute:'2-digit'});el.outerHTML=`<div id="lowBaseList"><div style="font-size:10px;color:var(--text3);padding:2px 4px 7px;display:flex;justify-content:space-between;"><span>📉 低基期候選（${valid.length}筆）</span><span style="cursor:pointer;color:var(--accent2);" onclick="lowBaseLoaded=false;loadLowBase()">↺</span></div>${valid.map((item,i)=>{const up=item.chgPct>=0;const pL=item.pct52!=null?`${item.pct52.toFixed(0)}%`:'—';const bC=item.pct52!=null&&item.pct52<30?'var(--down)':item.pct52<50?'var(--gold)':'var(--up)';return`<div class="lu-row" onclick="quickSearch('${item.id}')"><span class="lu-rank">${i+1}</span><div style="flex:1;min-width:0;margin:0 5px;"><div style="display:flex;justify-content:space-between;"><span class="lu-name">${item.name}</span><span style="font-size:12px;font-family:'JetBrains Mono',monospace;color:${up?'var(--up)':'var(--down)'};">${f2(item.price)}</span></div><div style="display:flex;align-items:center;gap:5px;margin-top:2px;"><span class="lu-code">${item.id}</span>${item.pct52!=null?`<div style="flex:1;height:3px;background:var(--border2);border-radius:2px;"><div style="width:${item.pct52.toFixed(0)}%;height:100%;background:${bC};border-radius:2px;"></div></div><span style="font-size:9px;color:var(--text3);">52W ${pL}</span>`:''}</div><div style="font-size:10px;color:var(--text3);margin-top:2px;">${item.reason}</div></div></div>`;}).join('')}<div style="font-size:10px;color:var(--text3);text-align:center;padding:7px 0 2px;">更新 ${now}</div></div>`;}

