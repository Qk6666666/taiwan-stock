const TREND_LIST=[{id:'2330',name:'台積電'},{id:'2303',name:'聯電'},{id:'2382',name:'廣達'},{id:'6669',name:'緯穎'},{id:'3231',name:'緯創'},{id:'2317',name:'鴻海'},{id:'2454',name:'聯發科'},{id:'3034',name:'聯詠'},{id:'3711',name:'日月光'},{id:'2379',name:'瑞昱'},{id:'2308',name:'台達電'},{id:'3017',name:'奇鋐'},{id:'2357',name:'華碩'},{id:'2412',name:'中華電'},{id:'2409',name:'友達'},{id:'3481',name:'群創'},{id:'2002',name:'中鋼'},{id:'1303',name:'南亞'},{id:'6505',name:'台塑化'},{id:'2603',name:'長榮'},{id:'2882',name:'國泰金'},{id:'2891',name:'中信金'}];
let trendLoaded=false;
async function loadTrend(){if(trendLoaded)return;const el=document.getElementById('trendList');if(!el)return;el.innerHTML='<div style="text-align:center;padding:14px 0;"><div class="spinner" style="width:18px;height:18px;margin:0 auto 7px;"></div><div style="font-size:11px;color:var(--text3);">分析趨勢股…</div></div>';const results=await Promise.allSettled(TREND_LIST.map(async c=>{const[q,cs]=await Promise.all([fetchQuote(c.id).catch(()=>null),fetchKline(c.id,'1mo','1d').catch(()=>[])]);return{...c,q,cs};}));const scored=results.filter(r=>r.status==='fulfilled'&&r.value.q?.regularMarketPrice).map(r=>{const{id,name,q,cs}=r.value;const price=q.regularMarketPrice;const wkH=q.fiftyTwoWeekHigh||price,wkL=q.fiftyTwoWeekLow||price;const pct52=((price-wkL)/(wkH-wkL)*100);const chgPct=q.regularMarketChangePercent||0;let score=0;if(cs.length>=10){const last10=cs.slice(-10);const ma5=last10.slice(-5).reduce((a,c)=>a+c.c,0)/5;const ma10=last10.reduce((a,c)=>a+c.c,0)/10;if(ma5>ma10)score+=3;const risingDays=last10.filter((c,i)=>i>0&&c.c>last10[i-1].c).length;score+=risingDays;const recentChg=last10.length>=2?((last10[last10.length-1].c-last10[0].c)/last10[0].c*100):0;score+=Math.min(recentChg/2,5);if(cs.length>=20){const avgV=cs.slice(-20,-3).reduce((a,c)=>a+(c.v||0),0)/17;const recentVol=cs.slice(-3).reduce((a,c)=>a+(c.v||0),0)/3;if(avgV>0&&recentVol/avgV>1.5)score+=2;}}if(pct52>60)score+=2;if(chgPct>1)score+=1;return{id,name,price,pct52,chgPct,score};}).sort((a,b)=>b.score-a.score).slice(0,15);if(!scored.length){el.innerHTML='<div style="font-size:11px;color:var(--text3);text-align:center;padding:14px;">載入失敗</div>';return;}trendLoaded=true;const now=new Date().toLocaleString('zh-TW',{hour12:false,hour:'2-digit',minute:'2-digit'});el.outerHTML=`<div id="trendList"><div style="font-size:10px;color:var(--text3);padding:2px 4px 7px;display:flex;justify-content:space-between;"><span>📈 趨勢強勢股（${scored.length}筆）</span><span style="cursor:pointer;color:var(--accent2);" onclick="trendLoaded=false;loadTrend()">↺</span></div>${scored.map((item,i)=>{const up=item.chgPct>=0;const pctBar=Math.min(100,Math.max(0,item.pct52||0));const barColor=item.pct52>70?'var(--up)':item.pct52>40?'var(--gold)':'var(--down)';const sec=SECTOR_DB[item.id];return`<div class="lu-row" onclick="quickSearch('${item.id}')"><span class="lu-rank">${i+1}</span><div style="flex:1;min-width:0;margin:0 5px;"><div style="display:flex;justify-content:space-between;"><span class="lu-name">${item.name}</span><span style="font-size:12px;font-family:'JetBrains Mono',monospace;color:${up?'var(--up)':'var(--down)'};">${f2(item.price)}</span></div><div style="display:flex;align-items:center;gap:4px;margin-top:2px;"><span class="lu-code">${item.id}</span>${sec?`<span style="font-size:9px;color:var(--text3);">${sec[1]}</span>`:''}<span style="font-size:10px;color:${up?'var(--up)':'var(--down)'};">${up?'+':''}${item.chgPct.toFixed(2)}%</span></div><div style="display:flex;align-items:center;gap:5px;margin-top:3px;"><div style="flex:1;height:3px;background:var(--border2);border-radius:2px;"><div style="width:${pctBar.toFixed(0)}%;height:100%;background:${barColor};border-radius:2px;"></div></div><span style="font-size:9px;color:var(--text3);">強度${item.score.toFixed(0)}</span></div></div></div>`;}).join('')}<div style="font-size:10px;color:var(--text3);text-align:center;padding:7px 0 2px;">更新 ${now}</div></div>`;}

// ─── 勝率排行 ───
const WINRATE_LIST=[{id:'2330',name:'台積電'},{id:'2303',name:'聯電'},{id:'2454',name:'聯發科'},{id:'2382',name:'廣達'},{id:'6669',name:'緯穎'},{id:'3231',name:'緯創'},{id:'2317',name:'鴻海'},{id:'2308',name:'台達電'},{id:'3017',name:'奇鋐'},{id:'3711',name:'日月光'},{id:'2379',name:'瑞昱'},{id:'3034',name:'聯詠'},{id:'2353',name:'宏碁'},{id:'2357',name:'華碩'},{id:'2409',name:'友達'},{id:'3481',name:'群創'},{id:'2002',name:'中鋼'},{id:'1303',name:'南亞'},{id:'6505',name:'台塑化'},{id:'2603',name:'長榮'},{id:'2882',name:'國泰金'},{id:'2891',name:'中信金'},{id:'2412',name:'中華電'},{id:'0050',name:'元大台灣50'},{id:'2337',name:'旺宏'},{id:'6770',name:'力積電'},{id:'2884',name:'玉山金'},{id:'1301',name:'台塑'}];
let winrateLoaded=false;
async function loadWinRate(){if(winrateLoaded)return;const el=document.getElementById('winrateList');if(!el)return;el.innerHTML='<div style="text-align:center;padding:14px 0;"><div class="spinner" style="width:18px;height:18px;margin:0 auto 7px;"></div><div style="font-size:11px;color:var(--text3);">AI 分析勝率中…</div></div>';const results=await Promise.allSettled(WINRATE_LIST.map(async item=>{const[q,cs]=await Promise.all([fetchQuote(item.id).catch(()=>null),fetchKline(item.id,'1mo','1d').catch(()=>[])]);return{...item,q,cs};}));const scored=results.filter(r=>r.status==='fulfilled'&&r.value.q?.regularMarketPrice).map(r=>{const{id,name,q,cs}=r.value;const price=q.regularMarketPrice;const wkH=q.fiftyTwoWeekHigh||price*1.2;const wkL=q.fiftyTwoWeekLow||price*0.8;const pct52=((price-wkL)/(wkH-wkL)*100);const chgPct=q.regularMarketChangePercent||0;const pe=q.trailingPE?+q.trailingPE:null;let techScore=0,ma5=null,ma20=null;if(cs.length>=5){ma5=cs.slice(-5).reduce((a,c)=>a+c.c,0)/5;if(cs.length>=20)ma20=cs.slice(-20).reduce((a,c)=>a+c.c,0)/20;const rising5=cs.slice(-5).filter((c,i,a)=>i>0&&c.c>a[i-1].c).length;techScore+=rising5;if(ma5&&ma20)techScore+=(ma5>ma20?3:-3);if(cs.length>=10){const r10=((cs[cs.length-1].c-cs[cs.length-10].c)/cs[cs.length-10].c*100);techScore+=Math.min(r10/2,4);}if(ma20&&price>ma20)techScore+=1;}let valScore=0;if(pct52<30)valScore+=2;if(pct52>60&&pct52<90)valScore+=3;if(pe&&pe<15)valScore+=2;if(pe&&pe>40)valScore-=2;if(chgPct>1)valScore+=1;const totalScore=techScore+valScore;const winrate=Math.min(82,Math.max(45,50+totalScore*2.5));return{id,name,price,chgPct,winrate,verdict:totalScore>=5?'buy':totalScore<=-3?'avoid':'wait'};}).sort((a,b)=>b.winrate-a.winrate).slice(0,15);if(!scored.length){el.innerHTML='<div style="font-size:11px;color:var(--text3);text-align:center;padding:14px;">載入失敗</div>';return;}winrateLoaded=true;const vmap={buy:{icon:'🟢'},wait:{icon:'🟡'},avoid:{icon:'🔴'}};const now=new Date().toLocaleString('zh-TW',{hour12:false,hour:'2-digit',minute:'2-digit'});el.outerHTML=`<div id="winrateList"><div style="font-size:10px;color:var(--text3);padding:2px 4px 5px;display:flex;justify-content:space-between;"><span>🏆 AI勝率排行（前15）</span><span style="cursor:pointer;color:var(--accent2);" onclick="winrateLoaded=false;loadWinRate()">↺</span></div><div style="font-size:9px;color:var(--text3);padding:0 4px 7px;">依技術面+估值綜合評分排序</div>${scored.map((s,i)=>{const up=s.chgPct>=0;const bW=Math.round(s.winrate);const bC=s.winrate>=68?'var(--up)':s.winrate>=58?'var(--gold)':'var(--text3)';const sec=SECTOR_DB[s.id];return`<div class="lu-row" onclick="quickSearch('${s.id}')"><span class="lu-rank" style="font-weight:700;color:${i<3?'var(--gold)':'var(--text3)'};">${i+1}</span><div style="flex:1;min-width:0;margin:0 5px;"><div style="display:flex;justify-content:space-between;"><span class="lu-name">${s.name}</span><span style="font-size:12px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${up?'var(--up)':'var(--down)'};">${f2(s.price)}</span></div><div style="display:flex;align-items:center;gap:4px;margin-top:2px;"><span class="lu-code">${s.id}</span>${sec?`<span style="font-size:9px;color:var(--text3);">${sec[1]}</span>`:''}<span style="font-size:10px;color:${up?'var(--up)':'var(--down)'};">${up?'+':''}${s.chgPct.toFixed(2)}%</span></div><div style="display:flex;align-items:center;gap:5px;margin-top:3px;"><div style="flex:1;height:5px;background:var(--border2);border-radius:3px;overflow:hidden;"><div style="width:${bW}%;height:100%;background:${bC};border-radius:3px;"></div></div><span style="font-size:11px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${bC};white-space:nowrap;">${s.winrate.toFixed(0)}%</span><span style="font-size:11px;">${(vmap[s.verdict]||vmap.wait).icon}</span></div></div></div>`;}).join('')}<div style="font-size:10px;color:var(--text3);text-align:center;padding:7px 0 2px;">更新 ${now}　⚠️ 僅供參考</div></div>`;}
</script>
</body>
