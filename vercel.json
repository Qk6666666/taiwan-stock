function renderRelated(id){const el=document.getElementById('relatedList');if(!el)return;const related=IM[id];if(!related||!related.length){el.innerHTML='<div class="empty-box">此股票暫無相關個股資料</div>';return;}const label=IL[id]||'同類';el.innerHTML=`<div style="font-size:12px;color:var(--text3);margin-bottom:11px;">${label} 族群</div><div class="related-grid">${related.map(rid=>`<div class="related-card" onclick="quickSearch('${rid}')"><div class="rc-name">${SN[rid]||rid}</div><div class="rc-code">${rid}.TW</div><div id="rp_${rid}" style="font-size:11px;color:var(--text3);margin-top:5px;">載入中…</div></div>`).join('')}</div>`;related.forEach(rid=>{fetchQuote(rid).then(q=>{const container=document.getElementById(`rp_${rid}`);if(!container||!q)return;const up=q.regularMarketChange>=0,cc=up?'up-c':'dn-c',tc=up?'up-tag':'dn-tag',sign=up?'+':'';container.innerHTML=`<div class="rc-price ${cc}">${f2(q.regularMarketPrice)}</div><div class="rc-change ${tc}">${sign}${(+q.regularMarketChangePercent).toFixed(2)}%</div>`;}).catch(()=>{});});}

// ─── AI Verdict ───
async function runAIVerdict(id,name,q,candles,news){
  const el=document.getElementById('verdictArea');if(!el)return;
  const rb=ruleBasedVerdict(id,q,candles);renderVerdict(rb,q,false);
  const price=q.regularMarketPrice;const wkHigh=q.fiftyTwoWeekHigh,wkLow=q.fiftyTwoWeekLow;const pct52=wkHigh&&wkLow?((price-wkLow)/(wkHigh-wkLow)*100).toFixed(1):null;const changeP=(+q.regularMarketChangePercent).toFixed(2);const pe=q.trailingPE?((+q.trailingPE).toFixed(1)):null;
  let trendDesc='無K線資料';if(candles.length>=2){const last=candles.slice(-10);const first=last[0].c,lastC=last[last.length-1].c;const chg=((lastC-first)/first*100).toFixed(2);trendDesc=`近10根K棒：起${first.toFixed(2)}→收${lastC.toFixed(2)}（${chg>0?'+':''}${chg}%）`;}
  let chipSummary='籌碼資料未載入';if(CHIPS_DATA){const inst=CHIPS_DATA.inst,margin=CHIPS_DATA.margin;if(inst)chipSummary=`三大法人淨${inst.total>0?'買超':'賣超'}${fmn(Math.abs(inst.total))}張（外資${inst.foreign.net>0?'+':''}${fmn(inst.foreign.net)}，投信${inst.trust.net>0?'+':''}${fmn(inst.trust.net)}）`;if(margin)chipSummary+=(CHIPS_DATA.inst?'；':'')+`融資${fmn(margin.marginBalance)}（${margin.marginChange>=0?'增':'減'}${fmn(Math.abs(margin.marginChange))}），券資比${((margin.shortBalance/(margin.marginBalance||1))*100).toFixed(1)}%`;}
  const newsH=news.slice(0,4).map(n=>n.title).join('\n');
  const prompt=`你是專業台股投資顧問，請對「${name}（${id}）」做綜合進場評估。\n\n現價：${f2(price)}　今日漲跌：${changeP}%　52週區間：${f2(wkLow)}～${f2(wkHigh)}（目前${pct52??'—'}%位置）　本益比：${pe??'無'}　K線：${trendDesc}　籌碼：${chipSummary}　近期新聞：${newsH||'無'}\n\n請以JSON回覆：{"verdict":"buy"或"wait"或"avoid","confidence":1到100整數,"summary":"2句話總結","entry_price":進場價數字,"entry_reason":"說明","stop_loss":停損價數字,"risk_reward":"風險報酬比","bull_factors":["看多1","看多2","看多3"],"bear_factors":["看空1","看空2"],"overall_reason":"3句話分析","short_term":{"period":"1～5個交易日","outlook":"bullish|bearish|neutral","target":目標價,"key_factor":"關鍵因素","strategy":"操作建議"},"mid_term":{"period":"1～4週","outlook":"bullish|bearish|neutral","target":目標價,"key_factor":"關鍵因素","strategy":"操作建議"},"long_term":{"period":"1～3個月","outlook":"bullish|bearish|neutral","target":目標價,"key_factor":"關鍵因素","strategy":"操作建議"}}`;
  try{const txt=await callClaude('你是專業台股投資分析師，提供客觀具體分析。只回覆JSON，不加說明或markdown。',prompt);const p=JSON.parse(txt);renderVerdict(p,q,true);}catch(e){const badge=document.getElementById('verdictSourceBadge');if(badge){badge.textContent='📊 規則型分析（AI 無法連線）';badge.style.background='rgba(240,160,48,.1)';badge.style.color='var(--gold)';badge.style.borderColor='rgba(240,160,48,.3)';}}
}
function ruleBasedVerdict(id,q,candles){const price=q.regularMarketPrice;const wkHigh=q.fiftyTwoWeekHigh||price*1.2;const wkLow=q.fiftyTwoWeekLow||price*0.8;const pct52=((price-wkLow)/(wkHigh-wkLow)*100);const changeP=q.regularMarketChangePercent||0;const pe=q.trailingPE;let trendScore=0,ma5=null,ma20=null;if(candles.length>=5){const last=candles.slice(-5);ma5=last.reduce((a,c)=>a+c.c,0)/5;if(candles.length>=20)ma20=candles.slice(-20).reduce((a,c)=>a+c.c,0)/20;const rising=candles.slice(-5).filter((c,i,a)=>i>0&&c.c>a[i-1].c).length;trendScore+=rising-2;}if(ma5&&ma20)trendScore+=(ma5>ma20?2:-2);if(pct52<30)trendScore-=1;if(pct52>80)trendScore+=1;if(changeP>3)trendScore+=1;if(changeP<-3)trendScore-=1;const bullFactors=[],bearFactors=[];if(ma5&&ma20&&ma5>ma20)bullFactors.push('MA5 在 MA20 之上，短期趨勢偏多');else if(ma5&&ma20)bearFactors.push('MA5 在 MA20 之下，短期趨勢偏空');if(pct52<30)bearFactors.push(`股價在52週低點附近（低位${pct52.toFixed(0)}%）`);else if(pct52>75)bullFactors.push(`股價接近52週高點（${pct52.toFixed(0)}%），強勢格局`);if(changeP>2)bullFactors.push(`今日上漲 ${changeP.toFixed(2)}%`);else if(changeP<-2)bearFactors.push(`今日下跌 ${Math.abs(changeP).toFixed(2)}%`);if(pe&&pe<15)bullFactors.push(`本益比 ${pe} 倍，估值偏低`);else if(pe&&pe>30)bearFactors.push(`本益比 ${pe} 倍，估值偏高`);let verdict='wait',confidence=50;if(trendScore>=2){verdict='buy';confidence=55+Math.min(trendScore*5,20);}else if(trendScore<=-2){verdict='avoid';confidence=55+Math.min(Math.abs(trendScore)*5,20);}const support=ma5?Math.min(ma5,price*0.97):price*0.97;const entryPrice=parseFloat((Math.min(support,price*0.99)).toFixed(1));const stopLoss=parseFloat((entryPrice*0.95).toFixed(1));const capTarget=(base,pct)=>parseFloat((base*(1+Math.min(Math.max(pct/100,-0.10),0.10))).toFixed(2));return{verdict,confidence,summary:`基於技術面規則分析。${verdict==='buy'?'技術面偏多，可考慮分批進場。':verdict==='avoid'?'技術面偏空，建議觀望。':'技術面中性，建議等待更明確訊號。'}`,entry_price:entryPrice,entry_reason:`建議於 ${entryPrice} 附近分批進場`,stop_loss:stopLoss,risk_reward:`1:${((capTarget(entryPrice,10)-entryPrice)/(entryPrice-stopLoss)).toFixed(1)}`,bull_factors:bullFactors.length?bullFactors:['無明確看多因素'],bear_factors:bearFactors.length?bearFactors:['無明確看空因素'],overall_reason:`現價 ${f2(price)}，52週高低點 ${f2(wkHigh)}/${f2(wkLow)}，目前位於 ${pct52.toFixed(0)}% 位置。${ma5?`MA5=${f2(ma5)}${ma20?`，MA20=${f2(ma20)}`:''}。`:''}技術面評分 ${trendScore}。`,short_term:{period:'1～5個交易日',outlook:trendScore>=2?'bullish':trendScore<=-2?'bearish':'neutral',target:capTarget(entryPrice,trendScore>=2?5:-3),key_factor:ma5&&ma20?(ma5>ma20?'MA5上方，短線偏多':'MA5下方，短線偏弱'):'技術面觀察中',strategy:trendScore>=2?`偏多，可於 ${entryPrice} 附近試單`:trendScore<=-2?'偏弱，等待企穩':'觀望等突破'},mid_term:{period:'1～4週',outlook:trendScore>=1?'bullish':trendScore<=-1?'bearish':'neutral',target:capTarget(entryPrice,trendScore>=1?8:-5),key_factor:pct52>60?'52週強勢位置':pct52<30?'52週低位':'中線位置中性',strategy:trendScore>=1?'逢回分批佈局':'等均線形態確立後進場'},long_term:{period:'1～3個月',outlook:ma5&&ma20&&ma5>ma20?'bullish':'neutral',target:parseFloat((price*(1+(verdict==='buy'?0.15:verdict==='avoid'?-0.05:0.07))).toFixed(2)),key_factor:'長線需搭配基本面與籌碼面',strategy:verdict==='buy'?'基本面確認後可建立長線部位':'等待更明確的基本面支撐'}};}
function renderVerdict(p,q,isAI=false){
  const el=document.getElementById('verdictArea');if(!el)return;
  const vmap={buy:{cls:'verdict-bull',icon:'🟢',label:'建議進場',color:'#f04a58'},wait:{cls:'verdict-neu',icon:'🟡',label:'觀望等待',color:'#f0a030'},avoid:{cls:'verdict-bear',icon:'🔴',label:'建議迴避',color:'#1db870'}};
  const v=vmap[p.verdict]||vmap.wait;const price=q.regularMarketPrice;
  const bullList=(p.bull_factors||[]).map(f=>`<li style="margin-bottom:5px;">✅ ${f}</li>`).join('');const bearList=(p.bear_factors||[]).map(f=>`<li style="margin-bottom:5px;">⚠️ ${f}</li>`).join('');
  const srcBadge=isAI?`<span id="verdictSourceBadge" style="font-size:11px;background:rgba(91,94,244,.12);color:var(--accent2);border:1px solid rgba(91,94,244,.2);border-radius:4px;padding:2px 8px;">🤖 AI 深度分析</span>`:`<span id="verdictSourceBadge" style="font-size:11px;background:rgba(240,160,48,.1);color:var(--gold);border:1px solid rgba(240,160,48,.3);border-radius:4px;padding:2px 8px;">📊 規則型分析</span>`;
  const omap={bullish:{icon:'📈',color:'#f04a58',label:'偏多'},bearish:{icon:'📉',color:'#1db870',label:'偏空'},neutral:{icon:'➡️',color:'#f0a030',label:'中性'}};
  const terms=[{title:'短線',period:p.short_term?.period||'1～5個交易日',outlook:p.short_term?.outlook||'neutral',target:p.short_term?.target||price,key_factor:p.short_term?.key_factor||'',strategy:p.short_term?.strategy||''},{title:'中線',period:p.mid_term?.period||'1～4週',outlook:p.mid_term?.outlook||'neutral',target:p.mid_term?.target||price,key_factor:p.mid_term?.key_factor||'',strategy:p.mid_term?.strategy||''},{title:'長線',period:p.long_term?.period||'1～3個月',outlook:p.long_term?.outlook||'neutral',target:p.long_term?.target||price,key_factor:p.long_term?.key_factor||'',strategy:p.long_term?.strategy||''}];
  const termCards=terms.map(t=>{const om=omap[t.outlook]||omap.neutral;const chgPct=price>0?((t.target-price)/price*100):0;return`<div style="background:var(--bg3);border:1px solid var(--border2);border-radius:12px;padding:13px;"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px;"><div><span style="font-size:13px;font-weight:700;">${t.title}</span><span style="font-size:10px;color:var(--text3);margin-left:5px;">${t.period}</span></div><span style="font-size:11px;font-weight:600;color:${om.color};background:${om.color}18;border:1px solid ${om.color}30;border-radius:4px;padding:2px 7px;">${om.icon} ${om.label}</span></div><div style="display:flex;align-items:baseline;gap:7px;margin-bottom:7px;"><span style="font-size:10px;color:var(--text3);">目標</span><span style="font-size:17px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${om.color};">${f2(t.target)}</span><span style="font-size:11px;color:${chgPct>=0?'var(--up)':'var(--down)'};">${chgPct>=0?'+':''}${chgPct.toFixed(1)}%</span></div><div style="font-size:11px;color:var(--text3);margin-bottom:5px;">🔑 ${t.key_factor}</div><div style="font-size:11px;color:var(--text2);background:var(--bg2);border-radius:7px;padding:7px 9px;line-height:1.6;">📌 ${t.strategy}</div></div>`;}).join('');
  el.innerHTML=`<div class="verdict-box ${v.cls}"><div class="verdict-header"><div class="verdict-icon">${v.icon}</div><div style="flex:1;"><div style="display:flex;align-items:center;gap:9px;flex-wrap:wrap;"><div class="verdict-label" style="color:${v.color}">${v.label}</div>${srcBadge}</div><div class="verdict-sublabel">${p.summary||''}</div></div></div><div class="verdict-score-row"><div class="score-pill">信心度 <strong>${p.confidence??'—'}%</strong></div><div class="score-pill">風險報酬 <strong>${p.risk_reward||'—'}</strong></div><div class="score-pill">現價 <strong style="color:${v.color}">${f2(price)}</strong></div></div><div class="entry-grid"><div class="verdict-entry"><div class="entry-label">建議進場價</div><div class="entry-value" style="color:#f04a58;">${p.entry_price?f2(p.entry_price):'—'} 元</div><div class="entry-sub">${p.entry_reason||''}</div></div><div class="verdict-entry"><div class="entry-label">停損價</div><div class="entry-value" style="color:#1db870;">${p.stop_loss?f2(p.stop_loss):'—'} 元</div><div class="entry-sub">跌破此價位建議出場</div></div></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:11px;"><div style="background:var(--bg3);border-radius:10px;padding:11px;"><div style="font-size:11px;color:var(--text3);margin-bottom:7px;text-transform:uppercase;">看多因素</div><ul style="list-style:none;font-size:12px;color:var(--text2);line-height:1.7;">${bullList||'<li>無</li>'}</ul></div><div style="background:var(--bg3);border-radius:10px;padding:11px;"><div style="font-size:11px;color:var(--text3);margin-bottom:7px;text-transform:uppercase;">看空風險</div><ul style="list-style:none;font-size:12px;color:var(--text2);line-height:1.7;">${bearList||'<li>無</li>'}</ul></div></div><div style="font-size:13px;color:var(--text2);line-height:1.75;padding:11px 14px;background:var(--bg3);border-radius:10px;border:1px solid var(--border);margin-bottom:11px;">${p.overall_reason||''}</div><div style="margin-bottom:11px;"><div style="font-size:11px;color:var(--text3);text-transform:uppercase;margin-bottom:9px;display:flex;align-items:center;gap:6px;"><span style="width:3px;height:12px;background:var(--accent);border-radius:2px;display:inline-block;"></span>短中長期評估</div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">${termCards}</div></div><div class="verdict-disclaimer">⚠️ 本分析僅供參考，不構成投資建議。投資有風險，請自行判斷。</div></div>`;
}

// ─── 隔日預測 ───
async function runNextDayPrediction(id,q,candles,news){
  const el=document.getElementById('nextdayArea');if(!el)return;if(nextDayCache[id]){el.innerHTML=nextDayCache[id];return;}
  el.innerHTML='<div class="loading-box"><div class="spinner"></div>AI 整合技術面、籌碼面、消息面分析中…</div>';
  const price=q.regularMarketPrice;const name=q.longName||q.shortName||SN[id]||id;let ma5v=null,ma20v=null,rsiV=null,volRatio=null,techSummary='無K線資料';
  if(candles.length>=5){const n=candles.length;ma5v=candles.slice(-5).reduce((a,c)=>a+c.c,0)/5;if(n>=20)ma20v=candles.slice(-20).reduce((a,c)=>a+c.c,0)/20;if(n>=15){const gains=[],losses=[];for(let i=n-14;i<n;i++){const d=candles[i].c-candles[i-1].c;if(d>0)gains.push(d);else losses.push(-d);}const ag=gains.reduce((a,b)=>a+b,0)/14,al=losses.reduce((a,b)=>a+b,0)/14;rsiV=al===0?100:100-(100/(1+ag/al));}if(n>=20){const avgV=candles.slice(-20,-3).reduce((a,c)=>a+(c.v||0),0)/17;const recV=candles.slice(-3).reduce((a,c)=>a+(c.v||0),0)/3;if(avgV>0)volRatio=recV/avgV;}const last5=candles.slice(-5);const risingDays=last5.filter((c,i)=>i>0&&c.c>last5[i-1].c).length;const last=candles[n-1];const bodyPct=last?(Math.abs(last.c-last.o)/(last.h-last.l||1)*100):0;techSummary=`近5日上漲${risingDays}天。MA5=${ma5v?ma5v.toFixed(2):'—'}${ma20v?`，MA20=${ma20v.toFixed(2)}`:''}。${rsiV?`RSI=${rsiV.toFixed(1)}。`:''}${volRatio?`量比均量${volRatio.toFixed(1)}倍。`:''}最後一根${last&&last.c>last.o?'紅K':'黑K'}，實體${bodyPct.toFixed(0)}%。`;}
  let chipSummary='籌碼資料未預先載入';if(CHIPS_DATA){const inst=CHIPS_DATA.inst,margin=CHIPS_DATA.margin;if(inst)chipSummary=`三大法人淨${inst.total>0?'買超':'賣超'}${fmn(Math.abs(inst.total))}張，外資${inst.foreign.net>0?'+':''}${fmn(inst.foreign.net)}，投信${inst.trust.net>0?'+':''}${fmn(inst.trust.net)}`;if(margin)chipSummary+=(CHIPS_DATA.inst?'；':'')+`融資${fmn(margin.marginBalance)}（${margin.marginChange>=0?'增':'減'}${fmn(Math.abs(margin.marginChange))}），券資比${((margin.shortBalance/(margin.marginBalance||1))*100).toFixed(1)}%`;}
  const prompt=`預測「${name}（${id}）」明日K線走勢。現價：${f2(price)}。技術面：${techSummary}。籌碼面：${chipSummary}。消息面：${news.slice(0,3).map(n=>n.title).join('；')||'無'}。以JSON回覆：{"scenario":"bullish|bearish|neutral","confidence":50到80整數,"predicted_open":"高開|平開|低開","predicted_range":"預測區間說明","price_target_high":預測最高價,"price_target_low":預測最低價,"key_levels":["支撐","壓力"],"main_drivers":["驅動1","驅動2"],"risk_factors":["風險1"],"strategy":"明日操作建議","disclaimer":"此為AI機率預測"}`;
  try{const txt=await callClaude('你是台股技術分析師，只回覆JSON。',prompt);const p=JSON.parse(txt);const html=buildNextDayHtml(p,q,{ma5:ma5v,ma20:ma20v,rsi:rsiV,volRatio});nextDayCache[id]=html;el.innerHTML=html;}catch(e){const p={scenario:'neutral',confidence:55,predicted_open:q.regularMarketChangePercent>1?'高開':q.regularMarketChangePercent<-1?'低開':'平開',predicted_range:'現價±2～3%',price_target_high:parseFloat((q.regularMarketPrice*1.03).toFixed(2)),price_target_low:parseFloat((q.regularMarketPrice*0.97).toFixed(2)),key_levels:[`支撐：${(q.regularMarketPrice*0.97).toFixed(2)}`,`壓力：${(q.regularMarketPrice*1.03).toFixed(2)}`],main_drivers:['技術面觀察中','量能方向待確認'],risk_factors:['外資動向不明'],strategy:'震盪格局，等待方向明確後再操作',disclaimer:'此為規則型預測，請謹慎參考'};const html=buildNextDayHtml(p,q,{ma5:ma5v,ma20:ma20v,rsi:rsiV,volRatio});nextDayCache[id]=html;el.innerHTML=html;}
}
function buildNextDayHtml(p,q,tech){const price=q.regularMarketPrice;const smap={bullish:{color:'#f04a58',bg:'rgba(240,74,88,.06)',border:'rgba(240,74,88,.2)',icon:'📈',label:'偏多'},bearish:{color:'#1db870',bg:'rgba(29,184,112,.06)',border:'rgba(29,184,112,.2)',icon:'📉',label:'偏空'},neutral:{color:'#f0a030',bg:'rgba(240,160,48,.06)',border:'rgba(240,160,48,.2)',icon:'↔️',label:'震盪整理'}};const s=smap[p.scenario]||smap.neutral;const openMap={'高開':'⬆️ 高開','平開':'➡️ 平開','低開':'⬇️ 低開'};const hi=p.price_target_high||price*1.02,lo=p.price_target_low||price*0.98;const drivers=(p.main_drivers||[]).map(d=>`<li style="margin-bottom:4px;">🔹 ${d}</li>`).join('');const risks=(p.risk_factors||[]).map(d=>`<li style="margin-bottom:4px;">⚠️ ${d}</li>`).join('');const levels=(p.key_levels||[]).map(d=>`<div style="font-size:12px;color:var(--text2);padding:4px 0;border-bottom:1px solid var(--border);">${d}</div>`).join('');const techRow=[tech.ma5?`<span>MA5 <strong>${tech.ma5.toFixed(1)}</strong></span>`:'',tech.ma20?`<span>MA20 <strong>${tech.ma20.toFixed(1)}</strong></span>`:'',tech.rsi?`<span>RSI <strong style="color:${tech.rsi>70?'var(--up)':tech.rsi<30?'var(--down)':'var(--text)'}">${tech.rsi.toFixed(0)}</strong></span>`:'',tech.volRatio?`<span>量比 <strong>${tech.volRatio.toFixed(1)}x</strong></span>`:''].filter(Boolean).join('<span style="color:var(--text3);margin:0 4px;">·</span>');return`<div style="background:${s.bg};border:1px solid ${s.border};border-radius:14px;padding:17px 19px;"><div style="display:flex;align-items:center;gap:11px;margin-bottom:12px;flex-wrap:wrap;"><span style="font-size:26px;">${s.icon}</span><div style="flex:1;"><div style="display:flex;align-items:center;gap:9px;flex-wrap:wrap;"><span style="font-size:17px;font-weight:700;color:${s.color};">明日預測：${s.label}</span><span style="font-size:11px;background:var(--bg3);color:var(--text3);border:1px solid var(--border2);border-radius:4px;padding:2px 7px;">信心度 ${p.confidence}%</span><span style="font-size:11px;background:var(--bg3);color:var(--text3);border:1px solid var(--border2);border-radius:4px;padding:2px 7px;">${openMap[p.predicted_open]||p.predicted_open}</span></div><div style="font-size:12px;color:var(--text2);margin-top:3px;">${p.predicted_range||''}</div></div></div>${techRow?`<div style="display:flex;flex-wrap:wrap;gap:9px;font-size:11px;color:var(--text3);background:var(--bg3);border-radius:9px;padding:7px 11px;margin-bottom:12px;">${techRow}</div>`:''}<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:11px;"><div style="background:var(--bg3);border-radius:10px;padding:12px;"><div style="font-size:10px;color:var(--text3);margin-bottom:4px;text-transform:uppercase;">預測最高</div><div style="font-size:19px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--up);">${f2(hi)}</div><div style="font-size:10px;color:var(--text3);">+${((hi-price)/price*100).toFixed(2)}%</div></div><div style="background:var(--bg3);border-radius:10px;padding:12px;"><div style="font-size:10px;color:var(--text3);margin-bottom:4px;text-transform:uppercase;">預測最低</div><div style="font-size:19px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--down);">${f2(lo)}</div><div style="font-size:10px;color:var(--text3);">${((lo-price)/price*100).toFixed(2)}%</div></div></div><div style="background:var(--bg3);border-radius:10px;padding:11px;margin-bottom:11px;"><div style="font-size:10px;color:var(--text3);text-transform:uppercase;margin-bottom:7px;">關鍵價位</div>${levels}</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:11px;"><div style="background:var(--bg3);border-radius:10px;padding:11px;"><div style="font-size:10px;color:var(--text3);margin-bottom:7px;text-transform:uppercase;">主要驅動</div><ul style="list-style:none;font-size:12px;color:var(--text2);line-height:1.7;">${drivers}</ul></div><div style="background:var(--bg3);border-radius:10px;padding:11px;"><div style="font-size:10px;color:var(--text3);margin-bottom:7px;text-transform:uppercase;">主要風險</div><ul style="list-style:none;font-size:12px;color:var(--text2);line-height:1.7;">${risks}</ul></div></div><div style="background:rgba(91,94,244,.08);border:1px solid rgba(91,94,244,.2);border-radius:10px;padding:11px 13px;margin-bottom:9px;"><div style="font-size:10px;color:var(--accent2);margin-bottom:4px;text-transform:uppercase;">明日操作建議</div><div style="font-size:13px;color:var(--text);line-height:1.7;">${p.strategy||''}</div></div><div style="font-size:10px;color:var(--text3);">⚠️ ${p.disclaimer||'此為AI機率預測，不構成投資建議。'}　${new Date().toLocaleString('zh-TW',{hour12:false})}</div></div>`;}

