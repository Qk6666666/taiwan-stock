function getSectorTag(id){const s=SECTOR_DB[id];if(!s)return'';const colors={'電子上游':'rgba(91,94,244,.12)','電子中游':'rgba(91,94,244,.1)','電子下游':'rgba(91,94,244,.08)','金融':'rgba(29,184,112,.1)','傳產':'rgba(240,160,48,.1)','ETF':'rgba(130,150,255,.1)'};const textColors={'電子上游':'#7c7ff7','電子中游':'#818cf8','電子下游':'#9ca3ff','金融':'#4ade80','傳產':'#fbbf24','ETF':'#a5b4fc'};const bg=colors[s[0]]||'rgba(91,94,244,.1)';const tc=textColors[s[0]]||'var(--accent2)';return`<span class="sector-tag" style="background:${bg};color:${tc};border-color:${tc}30;">📂 ${s[0]}</span><span class="industry-tag">${s[1]}</span>`;}

function updateMarketBadge(){const b=document.getElementById('marketBadge');if(!b)return;const now=new Date();const day=now.getDay();const h=now.getHours(),m=now.getMinutes();const t=h*100+m;if(day===0||day===6){b.style.cssText='display:inline-flex;align-items:center;font-size:10px;padding:2px 7px;border-radius:4px;margin-top:2px;background:rgba(70,80,104,.15);color:var(--text3);border:1px solid var(--border2);';b.textContent='⚫ 休市';return;}if(t>=900&&t<=1330){b.style.cssText='display:inline-flex;align-items:center;font-size:10px;padding:2px 7px;border-radius:4px;margin-top:2px;background:rgba(29,184,112,.12);color:#4ade80;border:1px solid rgba(29,184,112,.25);';b.textContent='🟢 交易中';}else if(t>830&&t<900){b.style.cssText='display:inline-flex;align-items:center;font-size:10px;padding:2px 7px;border-radius:4px;margin-top:2px;background:rgba(240,160,48,.1);color:var(--gold);border:1px solid rgba(240,160,48,.25);';b.textContent='🟡 盤前';}else{b.style.cssText='display:inline-flex;align-items:center;font-size:10px;padding:2px 7px;border-radius:4px;margin-top:2px;background:rgba(70,80,104,.15);color:var(--text3);border:1px solid var(--border2);';b.textContent='⚫ 休市';}}
updateMarketBadge();setInterval(updateMarketBadge,30000);

let CUR='',CANDLES=[],QUOTE_DATA=null,NEWS_DATA=[],CHIPS_DATA=null,nextDayCache={};

// ─── Fetch 全部走 /api/proxy ───
async function pfetch(url,isText=false){
  const r=await fetch(P(url));if(!r.ok)throw new Error('proxy '+r.status);
  return isText?r.text():r.json();
}

async function fetchQuote(id){
  let q=null;
  try{const d=await pfetch(`https://query1.finance.yahoo.com/v7/finance/quote?symbols=${id}.TW&fields=regularMarketPrice,regularMarketChange,regularMarketChangePercent,regularMarketVolume,regularMarketOpen,regularMarketDayHigh,regularMarketDayLow,regularMarketPreviousClose,fiftyTwoWeekHigh,fiftyTwoWeekLow,longName,shortName,trailingPE,marketCap`);q=d?.quoteResponse?.result?.[0]||null;}catch(e){}
  try{
    const d=await pfetch(`https://query1.finance.yahoo.com/v8/finance/chart/${id}.TW?interval=1d&range=5d&includePrePost=false`);
    const res=d?.chart?.result?.[0];if(!res)return q;
    const m=res.meta||{};const qi=res.indicators?.quote?.[0]||{};const ts=res.timestamp||[];const last=ts.length-1;
    const todayO=qi.open?.[last],todayH=qi.high?.[last],todayL=qi.low?.[last];
    const truePrevClose=last>=1&&qi.close?.[last-1]?qi.close[last-1]:null;
    if(q){if(!q.regularMarketOpen&&todayO)q.regularMarketOpen=todayO;if(!q.regularMarketDayHigh&&todayH)q.regularMarketDayHigh=todayH;if(!q.regularMarketDayLow&&todayL)q.regularMarketDayLow=todayL;if(!q.fiftyTwoWeekHigh&&m.fiftyTwoWeekHigh)q.fiftyTwoWeekHigh=m.fiftyTwoWeekHigh;if(!q.fiftyTwoWeekLow&&m.fiftyTwoWeekLow)q.fiftyTwoWeekLow=m.fiftyTwoWeekLow;if(truePrevClose){q.regularMarketPreviousClose=truePrevClose;q.regularMarketChange=q.regularMarketPrice-truePrevClose;q.regularMarketChangePercent=(q.regularMarketChange/truePrevClose)*100;}}
    else{const pv=truePrevClose||m.previousClose||0;const price=m.regularMarketPrice||qi.close?.[last];if(!price)return null;q={regularMarketPrice:price,regularMarketChange:pv?price-pv:0,regularMarketChangePercent:pv?((price-pv)/pv)*100:0,regularMarketVolume:m.regularMarketVolume||qi.volume?.[last]||null,regularMarketOpen:todayO||null,regularMarketDayHigh:todayH||null,regularMarketDayLow:todayL||null,regularMarketPreviousClose:pv||null,fiftyTwoWeekHigh:m.fiftyTwoWeekHigh||null,fiftyTwoWeekLow:m.fiftyTwoWeekLow||null,longName:m.longName||SN[id]||id,shortName:m.shortName||SN[id]||id,trailingPE:null,marketCap:null};}
  }catch(e){}
  return q;
}

async function fetchKline(id,range,interval){
  try{const d=await pfetch(`https://query1.finance.yahoo.com/v8/finance/chart/${id}.TW?interval=${interval}&range=${range}&includePrePost=false`);const res=d?.chart?.result?.[0];if(!res)return[];const ts=res.timestamp||[];const q=res.indicators?.quote?.[0]||{};return ts.map((t,i)=>({t:new Date(t*1000),o:q.open?.[i],h:q.high?.[i],l:q.low?.[i],c:q.close?.[i],v:q.volume?.[i]})).filter(c=>c.o!=null&&c.h!=null&&c.l!=null&&c.c!=null);}catch(e){return[];}
}

async function fetchNews(id,name){
  const kw=encodeURIComponent(name||id);const cutoff=new Date();cutoff.setDate(cutoff.getDate()-14);
  const afterStr=`${cutoff.getFullYear()}-${String(cutoff.getMonth()+1).padStart(2,'0')}-${String(cutoff.getDate()).padStart(2,'0')}`;
  const srcs=[`https://news.google.com/rss/search?q=${id}+${kw}+台股+after:${afterStr}&hl=zh-TW&gl=TW&ceid=TW:zh-Hant`,`https://news.google.com/rss/search?q=${kw}+股票+after:${afterStr}&hl=zh-TW&gl=TW&ceid=TW:zh-Hant`];
  for(const src of srcs){try{const txt=await pfetch(src,true);if(!txt.includes('<item'))continue;const xml=new DOMParser().parseFromString(txt,'text/xml');const rawItems=Array.from(xml.querySelectorAll('item'));const items=rawItems.map(it=>{const gt=tag=>{const m=it.querySelector(tag);if(!m)return'';return(m.textContent||'').replace(/<!--\[CDATA\[|\]\]-->/g,'').trim();};let link=gt('link');if(!link){const ln=it.getElementsByTagName('link')[0];link=ln?.getAttribute('href')||ln?.textContent||'#';}const pubDate=gt('pubDate');return{title:gt('title'),link,source:gt('source')||'財經新聞',pubDate,desc:gt('description').replace(/<[^>]+>/g,'').slice(0,140),ts:pubDate?new Date(pubDate).getTime():0};}).filter(it=>it.title&&it.title.length>4).filter(it=>!it.ts||it.ts>Date.now()-30*86400*1000).sort((a,b)=>b.ts-a.ts).slice(0,6);if(items.length>=1)return items;}catch(e){}}
  return[];
}

// 三大法人
async function fetchInstitutional(id){
  try{const d=await pfetch('https://www.twse.com.tw/rwd/zh/fund/T86?response=json&selectType=ALLBUT0999');if(!d?.data||!Array.isArray(d.data))return null;const row=d.data.find(r=>r[0]===id);if(!row)return null;const p=v=>parseInt((v||'0').replace(/,/g,''),10)||0;return{date:d.date||'最新',foreign:{buy:p(row[2]),sell:p(row[3]),net:p(row[4])},trust:{buy:p(row[5]),sell:p(row[6]),net:p(row[7])},dealer:{buy:p(row[8]),sell:p(row[9]),net:p(row[10])},total:p(row[11])};}catch(e){return null;}
}

// 融資融券
async function fetchMargin(id){
  const today=new Date();
  for(let back=0;back<5;back++){const d=new Date(today);d.setDate(d.getDate()-back);if(d.getDay()===0||d.getDay()===6)continue;const dateStr=`${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}`;try{const data=await pfetch(`https://www.twse.com.tw/rwd/zh/marginTrading/MI_MARGN?response=json&date=${dateStr}&selectType=ALL`);if(!data?.tables||!data.tables[0]?.data)continue;const rows=data.tables[0].data;const row=rows.find(r=>r[0]===id);if(!row)continue;const p=v=>parseInt((v||'0').replace(/,/g,''),10)||0;return{date:dateStr,marginBuy:p(row[2]),marginSell:p(row[3]),marginBalance:p(row[5]),marginChange:p(row[6]),shortSell:p(row[8]),shortBuy:p(row[9]),shortBalance:p(row[11]),shortChange:p(row[12])};}catch(e){}}
  return null;
}

// ─── AI ───
async function callClaude(system,userMsg){
  const res=await fetch('/api/claude',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:1000,system,userMsg})});
  if(!res.ok)throw new Error('api '+res.status);
  const d=await res.json();if(d.error)throw new Error(d.error);
  const txt=(d.content?.[0]?.text||'').replace(/```json|```/g,'').trim();if(!txt)throw new Error('empty');
  return txt;
}

