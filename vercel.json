function fdate(s){if(!s)return'';const d=new Date(s);return isNaN(d)?s:d.toLocaleString('zh-TW',{month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',hour12:false});}
function renderNews(id,items){const el=document.getElementById('newsList');if(!el)return;if(!items||!items.length){el.innerHTML=`<div style="padding:4px;"><p style="font-size:12px;color:var(--text3);margin-bottom:9px;">自動載入失敗，請直接前往：</p><div style="display:flex;flex-wrap:wrap;gap:8px;"><a href="https://tw.stock.yahoo.com/quote/${id}.TW/news" target="_blank" style="background:var(--bg4);border:1px solid var(--border2);border-radius:8px;padding:7px 13px;color:var(--accent2);font-size:13px;text-decoration:none;">📰 Yahoo 新聞</a><a href="https://www.cnyes.com/twstock/${id}" target="_blank" style="background:var(--bg4);border:1px solid var(--border2);border-radius:8px;padding:7px 13px;color:var(--accent2);font-size:13px;text-decoration:none;">📰 鉅亨網</a></div></div>`;return;}el.innerHTML=items.map((it,i)=>`<a class="news-item" href="${it.link}" target="_blank" rel="noopener"><div class="ni-title">${it.title}<span class="badge b-load" id="sent_${i}" style="margin-left:7px;">分析中</span></div><div class="ni-meta"><span class="ni-src">${it.source}</span><span class="ni-time">${fdate(it.pubDate)}</span></div>${it.desc?`<div class="ni-desc">${it.desc}…</div>`:''}</a>`).join('');items.forEach((it,i)=>analyzeSentiment(it.title,i));}
function reloadNews(){if(CUR)fetchNews(CUR,SN[CUR]||CUR).then(items=>{NEWS_DATA=items;renderNews(CUR,items);});}
async function analyzeSentiment(title,idx){const el=document.getElementById(`sent_${idx}`);if(!el)return;const map={bull:{cls:'b-bull',icon:'📈',lbl:'看好'},bear:{cls:'b-bear',icon:'📉',lbl:'看壞'},neutral:{cls:'b-neu',icon:'➡️',lbl:'中性'}};const bW=['上漲','大漲','突破','創高','看好','樂觀','買超','獲利','漲停','新高','利多','調升','轉盈'];const brW=['下跌','大跌','跌破','看壞','悲觀','賣超','虧損','衰退','跌停','新低','利空','調降'];const bS=bW.filter(w=>title.includes(w)).length,brS=brW.filter(w=>title.includes(w)).length;const quick=bS>brS?'bull':brS>bS?'bear':'neutral';const sq=map[quick];el.className=`badge ${sq.cls}`;el.textContent=`${sq.icon} ${sq.lbl}`;try{const txt=await callClaude('你是台股財經新聞情緒分析師。只回覆JSON：{"sentiment":"bull"|"bear"|"neutral","reason":"一句話"}',`分析：「${title}」`);const p=JSON.parse(txt);const s=map[p.sentiment]||map.neutral;const now=document.getElementById(`sent_${idx}`);if(now){now.className=`badge ${s.cls}`;now.title=p.reason||'';now.textContent=`${s.icon} ${s.lbl}`;}}catch(e){}}

